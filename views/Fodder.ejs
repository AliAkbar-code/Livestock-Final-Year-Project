    <style>
        body {
            margin: 0;
            font-family: 'Montserrat', sans-serif;
            color: #333;
        }

        /* Categories Button */
        .categories-button {
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 1000;
        }

        .categories-button button {
            padding: 10px 20px;
            background-color: #28a745;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .categories-list {
            display: none;
            margin-top: 0px;
            background-color: white;
            border: 1px solid #ddd;
            border-radius: 5px;
            padding: 10px 15px;
            position: absolute;
        }

        .categories-list.show {
            display: block;
        }

        .categories-list a {
            display: block;
            padding: 5px 10px;
            color: #333;
            text-decoration: none;
        }

        .categories-list a:hover {
            background-color: #f0f0f0;
        }

        /* Hero Section Full Screen */
        .hero-section {
            height: 100vh;
            display: flex;
            align-items: center;
            background-image: url('hero-background.jpg');
            /* Replace with your image URL */
            background-size: cover;
            background-position: center;
            color: black;
            padding: 0 20px;
            position: relative;
            overflow: hidden;
        }

        .hero-section::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: white;
            z-index: -1;
        }

        .hero-text {
            flex: 3;
            max-width: 75%;
            z-index: 1;
        }

        .hero-image {
            flex: 1;
            max-width: 25%;
        }

        .hero-image img {
            width: 100%;
            border-radius: 5px;
        }

        .hero-section h1 {
            font-size: 3rem;
            margin-bottom: 20px;
        }

        .hero-section p {
            font-size: 1.5rem;
            margin-bottom: 30px;
        }

        .hero-section button {
            padding: 15px 30px;
            background-color: #ffc107;
            color: #333;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 1.2rem;
        }


        /* Blogs Section Horizontal Layout */
        .blogs-section {
            padding: 50px 20px;
            background-color: #ffffff;
            text-align: center;
            overflow-x: auto;
            white-space: nowrap;
        }

        .blogs-section h2 {
            margin-bottom: 30px;
            font-size: 2.5rem;
            color: #333;
        }

        .blog-card {
            display: inline-block;
            background-color: #f7f7f7;
            padding: 20px;
            margin: 0 10px;
            width: 300px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            text-align: left;
            vertical-align: top;
            white-space: normal;
            transition: transform 0.3s;
        }

        .blog-card h3 {
            margin-bottom: 10px;
            font-size: 1.8rem;
            color: #28a745;
        }

        .blog-card p {
            color: #555;
        }

        .blog-card:hover {
            transform: translateY(-5px);
        }
    </style>
