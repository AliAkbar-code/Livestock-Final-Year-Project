    <!-- Custom Script for Carousel Functionality -->
    <script>
        function toggleCategories() {
            var list = document.getElementById('categories-list');
            list.classList.toggle('show');
        }
        document.addEventListener('DOMContentLoaded', function () {
            const container = document.querySelector('.animal-container');
            const items = document.querySelectorAll('.animal-item');
            const itemWidth = items[0].offsetWidth + 30; // Include margin-right
            const visibleItems = Math.floor(container.offsetWidth / itemWidth); // Number of visible items at once
            const totalWidth = itemWidth * items.length;
            let currentIndex = 0;

            // Ensure container width is enough to display all items
            container.style.width = `${totalWidth}px`;

            document.querySelector('.right-arrow').addEventListener('click', () => {
                if (currentIndex < items.length - visibleItems) {
                    currentIndex++;
                    container.style.transform = `translateX(-${itemWidth * currentIndex}px)`;
                }
            });

            document.querySelector('.left-arrow').addEventListener('click', () => {
                if (currentIndex > 0) {
                    currentIndex--;
                    container.style.transform = `translateX(-${itemWidth * currentIndex}px)`;
                }
            });
        });
    </script>
